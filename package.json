{
  "name": "text-dither",
  "version": "0.1.0",
  "description": "Order-preserving typographic halftone web app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "optimize:example": "vpype read examples/plot-example.svg linemerge --tolerance 0.05mm linesort linesimplify --tolerance 0.02mm write --page-size a3 --center examples/plot-example-optimized.svg"
  },
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "fast-xml-parser": "^5.8.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
